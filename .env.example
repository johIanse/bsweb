# Copy to .env and change all secrets before first deploy
APP_ENV=production
APP_DEBUG=0
APP_URL=http://localhost:8088

DB_HOST=step-mysql
DB_NAME=step_system
DB_USER=step_user
DB_PASS=CHANGE_ME_STRONG_DB_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD

# One-time install protection token for /install.php
INSTALL_TOKEN=CHANGE_ME_LONG_RANDOM_TOKEN
